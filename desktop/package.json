{
  "name": "@sharepaste/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/@tauri-apps/cli/index.js dev",
    "tauri": "node ../node_modules/@tauri-apps/cli/index.js",
    "build": "npm run frontend:build",
    "frontend:dev": "node ../node_modules/vite/bin/vite.js",
    "frontend:build": "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node ../node_modules/vite/bin/vite.js build",
    "lint": "node ../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('desktop: no unit tests yet')\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  }
}
