{
  "name": "@sharepaste/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "lint": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.1",
    "@grpc/proto-loader": "^0.8.0",
    "nanoid": "^5.1.6",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
