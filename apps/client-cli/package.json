{
  "name": "@sharepaste/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "sharepaste-client": "dist/src/cli.js"
  },
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs src/cli.ts",
