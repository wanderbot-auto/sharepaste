{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../web",
    "distDir": "../web",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "SharePaste Windows",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "systemTray": {
      "iconPath": "icons/tray.png"
    },
    "bundle": {
      "active": false,
      "identifier": "dev.sharepaste.desktop.windows",
      "icon": [
        "icons/icon.png",
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "title": "SharePaste",
        "width": 520,
        "height": 860,
        "minWidth": 520,
        "minHeight": 860,
        "maxWidth": 520,
        "maxHeight": 860,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
