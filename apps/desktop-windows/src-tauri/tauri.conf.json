{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../web",
    "distDir": "../web"
  },
  "package": {
    "productName": "SharePaste Windows",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "systemTray": {
      "iconPath": "icons/tray.png"
    },
    "bundle": {
      "active": false,
      "identifier": "dev.sharepaste.desktop.windows"
    },
    "windows": [
      {
        "title": "SharePaste",
        "width": 1240,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
